# Server
PORT=4000

# MongoDB
# Example: mongodb://127.0.0.1:27017/week8_demo
MONGODB_URI=mongodb://127.0.0.1:27017/week8_demo



# App
NODE_ENV=development
APP_NAME=week8_demo
BASE_URL=http://localhost:4000

# Logging
LOG_LEVEL=info

# Security / Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=1d
SESSION_SECRET=change_me_to_a_long_random_string
COOKIE_SECRET=change_me_to_a_long_random_string

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# MongoDB (optional auth params)
MONGODB_USER=
MONGODB_PASSWORD=

# Redis (optional)
REDIS_URL=redis://127.0.0.1:6379

# Email / SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com

# Observability (optional)
SENTRY_DSN=